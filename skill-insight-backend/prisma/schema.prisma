generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model answers {
  answer_id      Int       @id @default(autoincrement())
  question_id    Int
  answer_content String    @db.Text
  is_correct     Boolean?  @default(false)
  questions      questions @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: NoAction, map: "answers_ibfk_1")

  @@index([question_id], map: "question_id")
}

model exams {
  exam_id    Int       @id @default(autoincrement())
  teacher_id Int
  title      String    @db.VarChar(255)
  duration   Int
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [teacher_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "exams_ibfk_1")
  results    results[]

  @@index([teacher_id], map: "teacher_id")
}

model questions {
  question_id Int              @id @default(autoincrement())
  topic_id    Int
  content     String           @db.Text
  level       questions_level? @default(de)
  created_at  DateTime?        @default(now()) @db.Timestamp(0)
  answers     answers[]
  topics      topics           @relation(fields: [topic_id], references: [topic_id], onDelete: Cascade, onUpdate: NoAction, map: "questions_ibfk_1")

  @@index([topic_id], map: "topic_id")
}

model results {
  result_id  Int       @id @default(autoincrement())
  student_id Int
  exam_id    Int
  score      Decimal?  @db.Decimal(5, 2)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [student_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "results_ibfk_1")
  exams      exams     @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade, onUpdate: NoAction, map: "results_ibfk_2")

  @@index([exam_id], map: "exam_id")
  @@index([student_id], map: "student_id")
}

model subjects {
  subject_id   Int      @id @default(autoincrement())
  subject_name String   @db.VarChar(255)
  topics       topics[]
}

model topics {
  topic_id   Int         @id @default(autoincrement())
  subject_id Int
  topic_name String      @db.VarChar(255)
  questions  questions[]
  subjects   subjects    @relation(fields: [subject_id], references: [subject_id], onDelete: Cascade, onUpdate: NoAction, map: "topics_ibfk_1")

  @@index([subject_id], map: "subject_id")
}

model users {
  user_id    Int        @id @default(autoincrement())
  full_name  String     @db.VarChar(255)
  email      String     @unique(map: "email") @db.VarChar(255)
  password   String     @db.VarChar(255)
  role       users_role
  status     Boolean?   @default(true)
  created_at DateTime?  @default(now()) @db.Timestamp(0)
  exams      exams[]
  results    results[]
}

enum questions_level {
  de
  trung_binh
  kho
}

enum users_role {
  admin
  teacher
  student
}
