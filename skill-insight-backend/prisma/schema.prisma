generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  //url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// --- Models ---

model User {
  user_id    Int       @id @default(autoincrement())
  full_name  String    @db.VarChar(255)
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  role       UserRole  @default(STUDENT)
  status     Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime  @updatedAt

  // Relations
  exams           Exam[]           @relation("TeacherExams")
  results         Result[]
  managed_classes Class[]          @relation("TeacherManaged")
  enrollments     ClassEnrollment[]
  student_answers StudentAnswer[]

  @@map("users")
}

model Subject {
  subject_id   Int      @id @default(autoincrement())
  subject_name String   @db.VarChar(255)
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  topics Topic[]
  exams  Exam[]

  @@map("subjects")
}

model Topic {
  topic_id   Int      @id @default(autoincrement())
  subject_id Int
  topic_name String   @db.VarChar(255)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  subject   Subject    @relation(fields: [subject_id], references: [subject_id], onDelete: Cascade)
  questions Question[]

  @@map("topics")
}

model Question {
  question_id Int        @id @default(autoincrement())
  topic_id    Int
  content     String     @db.Text
  level       Difficulty @default(MEDIUM)
  created_at  DateTime?  @default(now()) @db.Timestamp(0)

  // Relations
  topic           Topic           @relation(fields: [topic_id], references: [topic_id], onDelete: Cascade)
  answers         Answer[]
  exam_questions  ExamQuestion[]
  student_answers StudentAnswer[]

  @@map("questions")
}

model Answer {
  answer_id      Int      @id @default(autoincrement())
  question_id    Int
  answer_content String   @db.Text
  is_correct     Boolean? @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  question        Question        @relation(fields: [question_id], references: [question_id], onDelete: Cascade)
  student_answers StudentAnswer[]

  @@map("answers")
}

model Exam {
  exam_id    Int       @id @default(autoincrement())
  teacher_id Int
  subject_id Int
  title      String    @db.VarChar(255)
  duration   Int // Phút
  created_at DateTime? @default(now()) @db.Timestamp(0)

  // Relations
  teacher        User             @relation("TeacherExams", fields: [teacher_id], references: [user_id], onDelete: Cascade)
  subject        Subject          @relation(fields: [subject_id], references: [subject_id])
  results        Result[]
  exam_questions ExamQuestion[]
  assignments    ExamAssignment[]

  @@map("exams")
}

model ExamQuestion {
  exam_id     Int
  question_id Int
  order_index Int @default(0)

  // Relations
  exam     Exam     @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [question_id], onDelete: Cascade)

  @@id([exam_id, question_id])
  @@map("exam_questions")
}

model Result {
  result_id  Int      @id @default(autoincrement())
  student_id Int
  exam_id    Int
  score      Decimal? @db.Decimal(5, 2)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  // Relations
  student         User            @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  exam            Exam            @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade)
  student_answers StudentAnswer[]

  @@map("results")
}

model StudentAnswer {
  student_answer_id Int @id @default(autoincrement())
  result_id         Int
  question_id       Int
  answer_id         Int
  student_id        Int
  is_correct        Boolean @default(false)

  // Relations
  result   Result   @relation(fields: [result_id], references: [result_id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [question_id])
  answer   Answer   @relation(fields: [answer_id], references: [answer_id])
  student  User     @relation(fields: [student_id], references: [user_id])

  @@map("student_answers")
}

model Class {
  class_id    Int      @id @default(autoincrement())
  class_name  String   @db.VarChar(255)
  class_code  String   @unique @db.VarChar(50)
  teacher_id  Int
  created_at  DateTime @default(now())

  // Relations
  teacher     User             @relation("TeacherManaged", fields: [teacher_id], references: [user_id])
  enrollments ClassEnrollment[]
  assignments ExamAssignment[]

  @@map("classes")
}

model ClassEnrollment {
  enrollment_id Int      @id @default(autoincrement())
  class_id      Int
  student_id    Int
  enrolled_at   DateTime @default(now())

  // Relations
  class   Class @relation(fields: [class_id], references: [class_id])
  student User  @relation(fields: [student_id], references: [user_id])

  @@map("class_enrollments")
}

model ExamAssignment {
  assignment_id Int      @id @default(autoincrement())
  exam_id       Int
  class_id      Int
  start_time    DateTime
  end_time      DateTime

  // Relations
  exam  Exam  @relation(fields: [exam_id], references: [exam_id])
  class Class @relation(fields: [class_id], references: [class_id])

  @@map("exam_assignments")
}